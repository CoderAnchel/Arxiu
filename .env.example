# =============================================================================
# Arxiu de notes — environment variables (copy to .env for local dev)
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=development                       # development | staging | production
APP_NAME=arxiu
LOG_LEVEL=INFO
TZ=Europe/Madrid

# --- Backend -----------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
BACKEND_PUBLIC_URL=http://localhost:8000

# JWT keys — generate with:
#   openssl genpkey -algorithm RSA -out jwt_private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in jwt_private.pem -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TTL_SECONDS=900                # 15 min
JWT_REFRESH_TTL_SECONDS=604800            # 7 days

# --- Database ----------------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=arxiu
MYSQL_USER=arxiu
MYSQL_PASSWORD=changeme_dev_only
MYSQL_ROOT_PASSWORD=changeme_root_dev_only
DATABASE_URL=mysql+asyncmy://arxiu:changeme_dev_only@mysql:3306/arxiu?charset=utf8mb4

# --- Redis (ARQ jobs + rate limit) ------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Google OAuth (optional secondary login) ---------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_ALLOWED_DOMAIN=inslaferreria.cat

# --- SMTP (email sending) ----------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_ADDRESS=no-reply@inslaferreria.cat
SMTP_FROM_NAME=Arxiu Institut la Ferreria

# --- Storage (uploads + generated PDFs) -------------------------------------
STORAGE_ROOT=/var/arxiu/storage           # mounted volume in compose

# --- Security / passwords ----------------------------------------------------
PASSWORD_BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=12
ADMIN_PASSWORD_REVEAL_TTL_SECONDS=300     # 5 min retrieval window for email-to-user
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_WRITE_PER_MINUTE=60

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# --- Frontend ----------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Arxiu Institut la Ferreria
